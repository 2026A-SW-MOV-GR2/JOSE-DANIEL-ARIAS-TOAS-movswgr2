<Page xmlns="http://schemas.nativescript.org/tns.xsd"
      navigatingTo="onNavigatingTo"
      backgroundColor="white">

  <ActionBar backgroundColor="#4A148C" color="white">
    <NavigationButton visibility="collapsed" />
    <ActionBar.titleView>
      <GridLayout columns="auto, *" verticalAlignment="center">
        <Label col="0" text="☰" fontSize="24" color="white" padding="10" tap="onMenuTap" />
        <Label col="1" text="🔐 Gestión de Secretos" fontSize="17" fontWeight="bold"
               color="white" verticalAlignment="center" marginLeft="10" />
      </GridLayout>
    </ActionBar.titleView>
  </ActionBar>

  <GridLayout>

    <!-- Contenido principal -->
    <ScrollView backgroundColor="white">
      <StackLayout padding="16" backgroundColor="white">

        <!-- Selector de mecanismo -->
        <Label text="Mecanismo de almacenamiento" class="section-title" />
        <ListView items="{{ mechanismOptions }}" height="180"
                  separatorColor="transparent"
                  itemTap="onMechanismSelect">
          <ListView.itemTemplate>
            <StackLayout padding="6">
              <GridLayout columns="*, auto"
                          backgroundColor="{{ selected ? '#EDE7F6' : '#F8F8F8' }}"
                          borderColor="{{ selected ? '#6200EE' : '#DDDDDD' }}"
                          borderWidth="{{ selected ? 2 : 1 }}"
                          borderRadius="8" padding="10">
                <StackLayout col="0">
                  <Label text="{{ label }}" fontSize="13" fontWeight="bold"
                         color="{{ selected ? '#4A148C' : '#333333' }}" />
                  <Label text="{{ description }}" fontSize="11" color="#666666"
                         textWrap="true" marginTop="2" />
                </StackLayout>
                <Label col="1" text="✓" fontSize="16" color="#6200EE"
                       verticalAlignment="center" marginLeft="8"
                       visibility="{{ selected ? 'visible' : 'collapsed' }}" />
              </GridLayout>
            </StackLayout>
          </ListView.itemTemplate>
        </ListView>

        <!-- Campos -->
        <Label text="Llave (Key)" class="section-title" marginTop="16" />
        <TextField hint="Ej: jwt_token" text="{{ key }}"
                   class="input-field" autocorrect="false" autocapitalizationType="none" />

        <Label text="Valor (Value)" class="section-title" marginTop="14" />
        <TextField hint="Ej: eyJhbGciOiJIUzI1NiJ9..." text="{{ value }}"
                   class="input-field" autocorrect="false" autocapitalizationType="none" />

        <!-- Botones -->
        <GridLayout columns="*, 12, *" marginTop="20">
          <Button col="0" text="💾  Guardar" tap="onSaveTap" class="btn-save" />
          <Button col="2" text="🔍  Recuperar" tap="onRetrieveTap" class="btn-retrieve" />
        </GridLayout>

        <!-- Resultado: encontrado -->
        <StackLayout class="result-box" visibility="{{ resultVisible ? 'visible' : 'collapsed' }}">
          <Label text="{{ resultText }}" class="result-text" textWrap="true" />
        </StackLayout>

        <!-- Resultado: no encontrado -->
        <StackLayout backgroundColor="#FFF3E0" borderRadius="8" padding="12"
                      marginTop="10"
                      visibility="{{ notFoundVisible ? 'visible' : 'collapsed' }}">
          <Label text="⚠️ Secreto no encontrado en este compartimento."
                 class="not-found-text" textWrap="true" />
        </StackLayout>

      </StackLayout>
    </ScrollView>

    <!-- Drawer overlay -->
    <GridLayout backgroundColor="rgba(0,0,0,0.4)" tap="onDrawerClose"
                 visibility="{{ drawerOpen ? 'visible' : 'collapsed' }}" />

    <!-- Drawer panel -->
    <StackLayout width="280" horizontalAlignment="left" backgroundColor="white"
                 visibility="{{ drawerOpen ? 'visible' : 'collapsed' }}">
      <StackLayout backgroundColor="#4A148C" padding="30 20">
        <Label text="🐾 PetApp" fontSize="24" fontWeight="bold" color="white" />
        <Label text="Taller Persistencia Dual" fontSize="13"
               color="rgba(255,255,255,0.8)" marginTop="4" />
      </StackLayout>
      <StackLayout padding="16">
        <Button text="📋  Mascotas"  tap="onNavMascotas"
                style="background-color:transparent;color:#333;text-align:left;padding:15;font-size:16;" />
        <Button text="🌐  API Rest"  tap="onNavAPI"
                style="background-color:transparent;color:#333;text-align:left;padding:15;font-size:16;" />
        <Button text="🔐  Secretos" tap="onNavSecretos"
                style="background-color:transparent;color:#333;text-align:left;padding:15;font-size:16;" />
      </StackLayout>
    </StackLayout>

  </GridLayout>
</Page>